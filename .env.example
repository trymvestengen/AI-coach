# AI Coach — eksempel på miljøvariabler
# Kopier til .env (backend) og .env.local (frontend). Aldri commit den ekte filen.

# ---------- LLM ----------
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6          # Hovedmodell for coach
LLM_FALLBACK_MODEL=claude-haiku-4-5  # Rask modell for enkle tool-svar

# ---------- Speech-to-Text ----------
DEEPGRAM_API_KEY=...
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=multi              # 'multi' lar Deepgram detektere no/en automatisk

# ---------- Text-to-Speech ----------
ELEVENLABS_API_KEY=...                # brukes for norsk
ELEVENLABS_VOICE_ID_NO=...
ELEVENLABS_MODEL=eleven_flash_v2_5

CARTESIA_API_KEY=...                  # brukes for engelsk
CARTESIA_VOICE_ID_EN=...
CARTESIA_MODEL=sonic-2

# ---------- Database ----------
# Supabase (eller Neon) Postgres connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/aicoach
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...         # KUN i backend, aldri i frontend

# ---------- Auth ----------
JWT_SECRET=change-me-long-random-string

# ---------- Backend ----------
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,https://ai-coach.vercel.app
LOG_LEVEL=info

# ---------- Frontend (web/.env.local) ----------
# Disse må ha NEXT_PUBLIC_-prefiks for å eksponeres i browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/voice
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# ---------- Observability (valgfritt i MVP) ----------
SENTRY_DSN=
POSTHOG_API_KEY=

# ---------- Feature flags ----------
ENABLE_VOICE=true
ENABLE_PERSONA_SWITCHER=true
DEFAULT_PERSONA=friend                # friend | sergeant | analyst
