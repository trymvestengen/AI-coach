{
  "permissions": {
    "deny": [
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Write(**/.env)",
      "Write(**/.env.local)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-checks.sh"
          }
        ]
      }
    ]
  }
}
